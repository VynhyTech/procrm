{
  "name": "real-estate-v1",
  "version": "2.0.0",
  "description": "Pool-based real estate CRM with interest-separated architecture",
  "scripts": {
    "postinstall": "prisma generate --no-hints",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "dev": "concurrently \"tsx watch src/server/serve.ts\" \"webpack serve\"",
    "build": "npm run build:web && npm run build:server",
    "build:web": "webpack --mode production",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "cross-env NODE_ENV=production node dist/server/server/serve.js",
    "db:generate": "prisma generate --no-hints",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx src/scripts/seed-scopes.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^9.1.3",
    "@prisma/adapter-mariadb": "7.8.0",
    "@prisma/client": "7.8.0",
    "@trpc/client": "^11.8.0",
    "@trpc/server": "^11.8.0",
    "argon2": "^0.44.0",
    "chart.js": "^4.4.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.2.0",
    "lucide-react": "^0.577.0",
    "mysql2": "^3.23.1",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zod": "^3.23.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@prisma/engines",
      "prisma"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "copy-webpack-plugin": "^14.0.0",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "esbuild": "^0.28.1",
    "esbuild-loader": "^4.2.2",
    "eslint": "^9.0.0",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "globals": "^15.0.0",
    "html-webpack-plugin": "^5.6.4",
    "postcss": "^8.4.47",
    "postcss-loader": "^7.3.4",
    "prisma": "7.8.0",
    "style-loader": "^4.0.0",
    "tailwindcss": "^3.4.13",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^6.0.0"
  }
}
